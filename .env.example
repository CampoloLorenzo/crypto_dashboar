# Copia in .env.local e compila. MAI committare .env.local.
# Configurare gli stessi valori anche nella dashboard Vercel.

ANTHROPIC_API_KEY=sk-ant-...
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=crypto_intel

# Opzionale: il free tier CoinGecko funziona anche senza key.
COINGECKO_API_KEY=

# Fase 4 — SOLO permessi read-only
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Notifiche push
NTFY_TOPIC=crypto-intel-francesco
NTFY_URL=https://ntfy.sh

# Protegge l'endpoint cron. Genera con: openssl rand -hex 32
CRON_SECRET=
